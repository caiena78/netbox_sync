# .env.example — copy to .env and fill in values
# All variables are prefixed with TRACER_

# ── NetBox ─────────────────────────────────────────────────────────────────────
TRACER_NETBOX_URL=https://netbox.example.com
TRACER_NETBOX_TOKEN=your_netbox_api_token_here
TRACER_NETBOX_VERIFY_SSL=true

# ── Device SSH credentials ──────────────────────────────────────────────────────
TRACER_DEVICE_USERNAME=admin
TRACER_DEVICE_PASSWORD=secret
TRACER_DEVICE_ENABLE_SECRET=
TRACER_DEVICE_TIMEOUT=30

# ── Vault (optional — leave blank to use the above credentials directly) ────────
TRACER_VAULT_ADDR=
TRACER_VAULT_ROLE_ID=
TRACER_VAULT_SECRET_ID=
TRACER_VAULT_MOUNT=secret
TRACER_VAULT_PATH=network/device

# ── API ──────────────────────────────────────────────────────────────────────────
TRACER_HOST=0.0.0.0
TRACER_PORT=8000
TRACER_RELOAD=false
# Comma-separated allowed CORS origins; use * for development only
TRACER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional API key protection (leave blank to disable)
TRACER_API_KEY=

# ── Performance ──────────────────────────────────────────────────────────────────
TRACER_MAX_HOPS=30
TRACER_TRACE_TIMEOUT_SECONDS=300
TRACER_MAX_CONCURRENT_TRACES=10
TRACER_MAX_L3_BRANCH_WORKERS=6

# ── Cache ────────────────────────────────────────────────────────────────────────
TRACER_NETBOX_PREFIX_CACHE_TTL=300
TRACER_TRACE_RESULT_CACHE_TTL=600
TRACER_TASK_TTL_SECONDS=3600
